# Copy to .env and fill in values. Never commit .env to git.

# --- Alfen charger -----------------------------------------------------------
ALFEN_HOST=10.0.100.20
ALFEN_USERNAME=admin
ALFEN_PASSWORD=your-alfen-admin-password
ALFEN_SOCKET=1
ALFEN_TLS_VERIFY=false

# --- Tag acquisition ---------------------------------------------------------
TAG_WAIT_TIMEOUT_S=15
TAG_POLL_INTERVAL_S=3
LOGIN_RATE_MAX=5
LOGIN_RATE_WINDOW_S=60

# --- EVCC REST ---------------------------------------------------------------
EVCC_BASE_URL=http://127.0.0.1:7070
EVCC_LOADPOINT_ID=1

# --- Behaviour ---------------------------------------------------------------
RELEASE_ON_DISCONNECT=true
# ON_UNKNOWN_TAG: "auto" (leave EVCC on auto-detection) or "default" (use DEFAULT_VEHICLE)
ON_UNKNOWN_TAG=auto
DEFAULT_VEHICLE=

# --- MQTT broker -------------------------------------------------------------
MQTT_HOST=127.0.0.1
MQTT_PORT=1883
MQTT_USERNAME=mqtt
MQTT_PASSWORD=your-mqtt-password
MQTT_TOPIC_PREFIX=evcc

# --- UID → vehicle map -------------------------------------------------------
# JSON object: normalised RFID UID (hex, no separators, uppercase) → EVCC vehicle name
# Run with LOG_LEVEL=DEBUG and LOG_UID_PLAINTEXT=true to discover unknown UIDs.
# Example: UID_VEHICLE_MAP={"04A1C2C5D4E5": "bmw320e", "04F6A5D2C3B4": "q6"}
UID_VEHICLE_MAP={"REPLACE_WITH_CARD_UID": "bmw320e"}

# --- Back-office / OCPP connectivity check -----------------------------------
# When enabled, the bridge reads BOConnection from /api/info on every
# vehicle-connect event (same Alfen session, no extra login) and sends a push
# notification if the value is not "online".
BACKOFFICE_CHECK_ENABLED=true

# HTTP POST target for push notifications (curl -d "<message>" <url>).
NOTIFY_URL=http://127.0.0.1:2586/evcc

# --- Logging -----------------------------------------------------------------
LOG_LEVEL=INFO
# Set LOG_UID_PLAINTEXT=true only during UID discovery — UIDs are personal identifiers
LOG_UID_PLAINTEXT=false
DRY_RUN=false
